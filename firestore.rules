// ============================================================
// firestore.rules - Firestore セキュリティルール
// ============================================================
// Firebase Console > Firestore > ルール タブに貼り付けてください。
//
// 【重要】本番運用前に必ず認証を追加してください。
// 下記のルールはイベント当日の簡易運用向けです。
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===========================================================
    // 【開発・テスト用】全員に読み書き許可
    // システムが正常に動作することを確認したら、
    // 下記の「本番運用ルール」に切り替えてください。
    // ===========================================================

    // ★ テスト用（全アクセス許可） ★
    // match /{document=**} {
    //   allow read, write: if true;
    // }


    // ===========================================================
    // 【推奨】IPアドレス制限がない場合の簡易セキュリティルール
    // 読み書きを許可するが、データの基本検証を行う
    // ===========================================================

    // 卓コレクション
    match /tables/{tableId} {
      // 読み取り: 全員許可
      allow read: if true;

      // 書き込み: 必須フィールドの検証
      allow create, update: if
        request.resource.data.tableNumber is string &&
        request.resource.data.tableNumber.size() > 0 &&
        request.resource.data.guestCount is number &&
        request.resource.data.guestCount >= 0;

      // 削除: 許可（必要に応じてfalseに変更）
      allow delete: if true;
    }

    // メニューコレクション
    match /menus/{menuId} {
      // 読み取り: 全員許可
      allow read: if true;

      // 書き込み: 必須フィールドの検証
      allow create, update: if
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.price is number &&
        request.resource.data.price >= 0;

      // 削除: 許可
      allow delete: if true;
    }

    // 注文コレクション
    match /orders/{orderId} {
      // 読み取り: 全員許可
      allow read: if true;

      // 新規注文の作成: 必須フィールドの検証
      allow create: if
        request.resource.data.tableNumber is string &&
        request.resource.data.tableNumber.size() > 0 &&
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.totalPrice is number &&
        request.resource.data.totalPrice >= 0;

      // 更新: ステータス変更・会計処理のみ許可
      allow update: if true;

      // 削除: 禁止（会計履歴を保持するため）
      allow delete: if false;
    }


    // ===========================================================
    // 【本番運用推奨】Firebase Authenticationを使用する場合
    //
    // 1. Firebase Console で Authentication を有効にする
    // 2. メール/パスワード認証またはGoogle認証を設定
    // 3. app.js の initApp() に firebase.auth().signIn() を追加
    // 4. 以下のルールに切り替える
    // ===========================================================

    // 認証済みユーザーのみ許可（本番推奨）
    // match /{document=**} {
    //   allow read, write: if request.auth != null;
    // }

  }
}
